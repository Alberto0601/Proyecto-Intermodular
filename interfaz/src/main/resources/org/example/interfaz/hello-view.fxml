<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.interfaz.Controlador"
           >

    <children>

        <VBox alignment="CENTER"
              maxWidth="350"
              spacing="15"
              styleClass="login-card">

            <children>

                <Label text="Bienvenido"
                       styleClass="title"/>

                <Label text="Inicia sesión para continuar"
                       styleClass="subtitle"/>

                <TextField fx:id="txtUsuario"
                           promptText="Usuario"/>

                <PasswordField fx:id="txtPassword"
                               promptText="Contraseña"/>

                <Button text="Iniciar sesión"
                        onAction="#iniciarSesion"
                        maxWidth="Infinity"
                        styleClass="login-button"/>

                <Label text="¿olvidaste tu contraseña?"
                       styleClass="subtitle"/><!--click para que te lleve a recuperarla si da tiempo-->

                <Label fx:id="lblMensaje"/>

            </children>

        </VBox>

    </children>

</StackPane>
