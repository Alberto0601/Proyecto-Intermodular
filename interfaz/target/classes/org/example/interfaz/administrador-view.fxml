<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.interfaz.ControladorAdministrador">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Gestión de Concursos"
           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <Button text="Dar de alta concurso"
            prefWidth="250"
            onAction="#darAltaConcurso"/><!--nombre de los métodos del controlador administrador-->

    <Button text="Modificar concurso"
            prefWidth="250"
            onAction="#modificarConcurso"/>

    <Button text="Dar de baja concurso"
            prefWidth="250"
            onAction="#darBajaConcurso"/>
</VBox>
